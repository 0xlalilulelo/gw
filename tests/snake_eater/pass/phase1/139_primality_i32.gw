fn is_prime(n: i32) -> bool {
    if n < 2 { return false; }
    if n == 2 { return true; }
    if n % 2 == 0 { return false; }
    let i: i32 = 3;
    while i * i <= n {
        if n % i == 0 { return false; }
        i = i + 2;
    }
    return true;
}

fn main() -> i32 {
    let count: i32 = 0;
    let n: i32 = 2;
    while n <= 30 {
        if is_prime(n) { count = count + 1; }
        n = n + 1;
    }
    return count;
}
