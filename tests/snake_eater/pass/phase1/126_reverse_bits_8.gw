fn reverse8(x: i32) -> i32 {
    let n: i32 = x;
    let r: i32 = 0;
    let i: i32 = 0;
    while i < 8 {
        r = (r << 1) | (n & 1);
        n = n >> 1;
        i = i + 1;
    }
    return r;
}

fn main() -> i32 {
    let a: i32 = reverse8(0x01);
    let b: i32 = reverse8(0xA5);
    if a == 0x80 {
        if b == 0xA5 { return 42; }
    }
    return 0;
}
