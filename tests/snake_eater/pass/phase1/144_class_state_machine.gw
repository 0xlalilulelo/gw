class Counter { value: i32, reset_count: i32 }

fn main() -> i32 {
    let c = Counter { .value = 0, .reset_count = 0 };
    let i: i32 = 0;
    while i < 12 {
        c.value = c.value + 1;
        if c.value == 5 {
            c.value = 0;
            c.reset_count = c.reset_count + 1;
        }
        i = i + 1;
    }
    return c.value * 10 + c.reset_count;
}
