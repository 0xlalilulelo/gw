fn collatz_max(n: i64) -> i64 {
    let v: i64 = n;
    let m: i64 = n;
    while v != 1 {
        if v % 2 == 0 {
            v = v / 2;
        } else {
            v = 3 * v + 1;
        }
        if v > m { m = v; }
    }
    return m;
}

fn main() -> i32 {
    let r: i64 = collatz_max(27);
    if r == 9232 { return 42; }
    return 0;
}
