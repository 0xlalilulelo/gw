fn round_up_pow2(x: i32) -> i32 {
    let n: i32 = x - 1;
    n = n | (n >> 1);
    n = n | (n >> 2);
    n = n | (n >> 4);
    n = n | (n >> 8);
    n = n | (n >> 16);
    return n + 1;
}

fn main() -> i32 {
    let a: i32 = round_up_pow2(5);
    let b: i32 = round_up_pow2(33);
    if a == 8 {
        if b == 64 { return 42; }
    }
    return 0;
}
