class EventLog { hits: i32, misses: i32, total: i32 }

fn main() -> i32 {
    let log = EventLog { .hits = 0, .misses = 0, .total = 0 };
    let i: i32 = 1;
    while i <= 10 {
        log.total = log.total + 1;
        if i % 3 == 0 {
            log.hits = log.hits + 1;
        } else {
            log.misses = log.misses + 1;
        }
        i = i + 1;
    }
    return log.hits * 100 + log.misses * 10 + log.total;
}
