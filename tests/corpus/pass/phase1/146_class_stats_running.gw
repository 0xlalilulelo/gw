class Stats { sum: f64, count: i32 }

fn main() -> i32 {
    let s = Stats { .sum = 0.0, .count = 0 };
    let i: i32 = 1;
    while i <= 4 {
        s.sum = s.sum + 0.5;
        s.count = s.count + 1;
        i = i + 1;
    }
    if s.sum == 2.0 {
        if s.count == 4 { return 42; }
    }
    return 0;
}
