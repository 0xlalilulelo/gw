fn parity(x: i32) -> i32 {
    let n: i32 = x;
    let p: i32 = 0;
    while n != 0 {
        p = p ^ (n & 1);
        n = n >> 1;
    }
    return p;
}

fn main() -> i32 {
    let a: i32 = parity(0x07);
    let b: i32 = parity(0xFF);
    if a == 1 {
        if b == 0 { return 42; }
    }
    return 0;
}
